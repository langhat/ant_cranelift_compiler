//usage:
//let v=vec_init<u8>(5usize);
//defer vec_free(v);
//
//v=vec_insert(v,0u8,91u8);
//(use v)...

func main() -> i32 {
	let v = vec_inita(5usize, 13i32);
	v = vec_insert(v, 1usize, 91i32);
	v = vec_insert(v, 2usize, 71i32);

	extern "C" func printf(s: str, ...) -> i32;

	printf("first: %d\n", vec_get(v, 0usize));
	printf("second: %d\n", vec_get(v, 1usize));
	printf("third: %d\n", vec_get(v, 2usize));
}