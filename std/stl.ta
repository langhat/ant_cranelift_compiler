extern "C" func printf(s: str, ...) -> i32;
extern "C" func malloc(size: usize) -> *u8;
extern "C" func free(ptr: *u8) -> u8;

struct Vec<T> {
	ptr: *T,
	size: usize
}

func vec_init<T>(size_: usize) -> Vec<T> {
	let o = new Vec {
		ptr = malloc(size_ * sizeof T) as *T,
		size = size_
	};

	o
}

func vec_free<T>(v: Vec<T>) {
	if v.size != 0usize {
		v.size = 0usize;
		free(v.ptr as *u8);
	}
}

func vec_get<T>(v: Vec<T>, p: usize) -> T {
	*(v.ptr + p)
}

func vec_post<T>(v: Vec<T>, p: usize, nv: T) {
	*(v.ptr + p) = nv;
}

func vec_ref<T>(v: Vec<T>, p: usize) -> *T {
	v.ptr + p
}

func vec_size<T>(v: Vec<T>) -> usize {
	v.size
}


func vec_begin<T> (v: Vec<T>) -> *T {
	v.ptr
}

func vec_end<T> (v: Vec<T>) -> *T {
	v.ptr+v.size
}

//need `for`
func vec_erase<T>(v: Vec<T>, p: usize) -> Vec<T> {
	let post = p;

	while post < v.size {
		vec_post(v,post, vec_get(v,post + 1usize));
		post = post + 1usize
	}
	
	v.size = v.size - 1usize;
	v
}

func vec_insert<T>(v: Vec<T>, p: usize, nv: T) -> Vec<T> {
	let o = new Vec {
        ptr = malloc((v.size + 1usize) * sizeof T) as *T,
        size = v.size + 1usize
    };

    let i = 0usize;
    while i < p {
        vec_post(o, i, vec_get(v, i));
        i = i + 1usize;
    }

    vec_post(o, p, nv);

    while i < v.size {
        vec_post(o, i + 1usize, vec_get(v, i));
        i = i + 1usize;
    }

	vec_free(v);
	o
}

func vec_find<T> (v: Vec<T>, content: T) -> *T {
    let i: usize = 0usize;

	while i < v.size {
		let pos = i;
		let current_val = vec_get(v, pos);
        if (current_val == content) {
            vec_ref(v, pos)
        }

		i = i + 1usize
	}

    vec_end(v)
}

func vec_swap<T> (v: Vec<T>, i: u8, j: usize) {
    let temp = vec_get(v, i);
    vec_post(v, i, vec_get(v, j));
    vec_post(v, j, temp);
}

func vec_inita<T>(size_: usize, first: T) -> Vec<T> {
	let o = new Vec {
		ptr = malloc(size_ * sizeof T) as *T,
		size = size_
	};

	o = vec_insert(o, 0usize, first);

	o
}

